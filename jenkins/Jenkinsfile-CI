pipeline {
    agent any

    parameters {
        booleanParam(name: 'BUILD_ALL', defaultValue: true, description: 'Build all services')
    }

    environment {
        DOCKER_USER = 'vandiemmy'
        REVISION = '1.0-SNAPSHOT'
        LOCAL_REGISTRY = 'localhost:5000'
    }

    triggers { githubPush() }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.COMMIT_ID = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    def gitBranch = sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()
                    env.BRANCH = env.BRANCH_NAME ?: (gitBranch == 'HEAD' ? 'detached' : gitBranch)
                    env.BRANCH_TAG = env.BRANCH.replaceAll('[^a-zA-Z0-9_.-]', '-')
                    echo "Using commit ${env.COMMIT_ID} on branch ${env.BRANCH}"
                }
            }
        }

        stage('Detect Changed Services') {
            steps {
                script {
                    def allServices = [
                        'cart','customer','inventory','location','media',
                        'order','product','rating','search','tax','webhook'
                    ]
                    if (params.BUILD_ALL) {
                        env.BUILD_SERVICES = allServices.join(',')
                        echo "Services to build (forced): ${env.BUILD_SERVICES}"
                        return
                    }
                    def changed = sh(
                        script: 'git diff --name-only HEAD~1 HEAD 2>/dev/null || echo "all"',
                        returnStdout: true
                    ).trim().split('\n').collect { it.split('/')[0] }

                    def toBuild = (changed.contains('all'))
                        ? allServices
                        : allServices.findAll { it in changed }

                    env.BUILD_SERVICES = toBuild ? toBuild.join(',') : allServices.join(',')
                    echo "Services to build: ${env.BUILD_SERVICES}"
                }
            }
        }

        stage('Build & Push') {
            steps {
                script {
                    sh """
                        cd cart
                        chmod +x mvnw
                        ./mvnw -q -U -DskipTests -Drevision=${REVISION} -f ../pom.xml -N install
                        ./mvnw -q -U -DskipTests -Drevision=${REVISION} -f ../pom.xml -pl common-library -am install
                        cd ..
                    """

                    withCredentials([usernamePassword(
                        credentialsId: 'dockerhub-cred',
                        usernameVariable: 'USER',
                        passwordVariable: 'PASS'
                    )]) {
                        sh "echo \$PASS | docker login -u \$USER --password-stdin"
                    }

                    env.BUILD_SERVICES.split(',').each { svc ->
                        svc = svc.trim()
                        if (!svc) return
                        sh """
                            cd cart
                            chmod +x mvnw
                            ./mvnw -q -U -DskipTests -Drevision=${REVISION} -f ../pom.xml -pl ${svc} -am package
                            cd ..
                            docker build \
                                -t ${DOCKER_USER}/${svc}:${COMMIT_ID} \
                                -t ${DOCKER_USER}/${svc}:${BRANCH_TAG} \
                                ./${svc}
                            docker tag ${DOCKER_USER}/${svc}:${COMMIT_ID} ${LOCAL_REGISTRY}/${svc}:${COMMIT_ID}
                            docker tag ${DOCKER_USER}/${svc}:${BRANCH_TAG} ${LOCAL_REGISTRY}/${svc}:${BRANCH_TAG}
                            docker push ${DOCKER_USER}/${svc}:${COMMIT_ID}
                            docker push ${DOCKER_USER}/${svc}:${BRANCH_TAG}
                            docker push ${LOCAL_REGISTRY}/${svc}:${COMMIT_ID}
                            docker push ${LOCAL_REGISTRY}/${svc}:${BRANCH_TAG}
                        """
                    }
                }
            }
        }
    }

    post {
        always { sh 'docker logout' }
        success { echo "CI done — commit: ${COMMIT_ID}" }
        failure { echo "CI failed" }
    }
}