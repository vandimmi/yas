pipeline {
    agent any

    parameters {
        string(name: 'cart_branch',      defaultValue: 'main')
        string(name: 'customer_branch',  defaultValue: 'main')
        string(name: 'inventory_branch', defaultValue: 'main')
        string(name: 'location_branch',  defaultValue: 'main')
        string(name: 'media_branch',     defaultValue: 'main')
        string(name: 'order_branch',     defaultValue: 'main')
        string(name: 'product_branch',   defaultValue: 'main')
        string(name: 'rating_branch',    defaultValue: 'main')
        string(name: 'search_branch',    defaultValue: 'main')
        string(name: 'tax_branch',       defaultValue: 'main')
        string(name: 'webhook_branch',   defaultValue: 'main')
    }

    environment {
        DOCKER_USER = 'vandiemmy'
        REGISTRY   = 'k3d-registry.localhost:5000'
        NAMESPACE   = 'developer'
        KUBECONFIG  = credentials('kubeconfig')
    }

    stages {
        stage('Create Namespace') {
            steps {
                sh "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"
            }
        }

        stage('Deploy Services') {
            steps {
                script {
                    def services = [
                        'cart','customer','inventory','location','media',
                        'order','product','rating','search','tax','webhook'
                    ]

                    services.each { svc ->
                        def branch = params["${svc}_branch"]
                        def tag = resolveTag(svc, branch)

                        echo "Deploying ${svc} with tag: ${tag}"

                        sh """
                            sed 's/nodePort: 300/nodePort: 310/g' k8s/${svc}/deployment.yaml | kubectl apply -n ${NAMESPACE} -f -
                            kubectl set image deployment/${svc} \
                                ${svc}=${REGISTRY}/${svc}:${tag} \
                                -n ${NAMESPACE}
                            kubectl rollout status deployment/${svc} -n ${NAMESPACE} --timeout=120s
                        """
                    }
                }
            }
        }

        stage('Print Access Info') {
            steps {
                script {
                    sh "kubectl get svc -n ${NAMESPACE}"

                    echo """ DEPLOYMENT COMPLETE!
                        Truy cập trực tiếp (k3d NodePort map):
                        http://localhost:30080  (storefront)
                        http://localhost:31081  (tax)
                        http://localhost:31082  (cart)
                        http://localhost:31083  (customer)
                        http://localhost:31084  (location)
                        http://localhost:31085  (media)
                        http://localhost:31086  (order)
                        http://localhost:31087  (product)
                        http://localhost:31088  (rating)
                        http://localhost:31089  (search)
                        http://localhost:31090  (inventory)
                        http://localhost:31091  (webhook)
                    """
                }
            }
        }
    }
}

def resolveTag(svc, branch) {
    if (!branch) {
        branch = getGitBranch()
    }
    if (!branch || branch == 'main' || branch == 'latest') return 'main'
    def commitId = sh(
        script: "git ls-remote https://github.com/vandimmi/yas.git refs/heads/${branch} | cut -c1-7",
        returnStdout: true
    ).trim()
    return commitId ?: 'main'
}

def getGitBranch() {
    def branch = sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()
    return branch == 'HEAD' ? null : branch
}
