pipeline {
    agent any

    environment {
        DOCKER_USER = 'vandiemmy'
        REGISTRY   = 'k3d-k3d-registry.localhost:5000'
        NAMESPACE   = 'dev'
        KUBECONFIG  = credentials('kubeconfig')
    }

    // Tự động trigger khi có push vào branch main
    triggers { githubPush() }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Branch') {
            steps {
                script {
                    def gitBranch = sh(script: 'git rev-parse --abbrev-ref HEAD', returnStdout: true).trim()
                    def actualBranch = env.BRANCH_NAME ?: env.GIT_BRANCH ?: (gitBranch == 'HEAD' ? '' : gitBranch)
                    if (!actualBranch) {
                        actualBranch = sh(script: 'git name-rev --name-only --no-undefined HEAD | sed "s#^origin/##"', returnStdout: true).trim()
                    }
                    if (!actualBranch || actualBranch == 'HEAD') {
                        actualBranch = 'detached'
                    }
                    def normalizedBranch = actualBranch?.replaceFirst('^origin/', '')
                    if (normalizedBranch != 'main') {
                        currentBuild.result = 'ABORTED'
                        error "Job này chỉ chạy trên branch main, hiện tại: ${normalizedBranch}"
                    }
                    echo "Branch hợp lệ: main"
                }
            }
        }

        stage('Create Namespace') {
            steps {
                sh "kubectl create namespace ${NAMESPACE} --dry-run=client -o yaml | kubectl apply -f -"
            }
        }

        stage('Deploy All Services') {
            steps {
                script {
                    def services = [
                        'cart','customer','inventory','location','media',
                        'order','product','rating','search','tax','webhook'
                    ]

                    services.each { svc ->
                        echo ">>> Deploying ${svc}:main to namespace ${NAMESPACE}"
                        sh """
                            kubectl apply -f k8s/${svc}/ -n ${NAMESPACE}
                            kubectl set image deployment/${svc} \
                                ${svc}=${REGISTRY}/${svc}:main \
                                -n ${NAMESPACE}
                            kubectl rollout status deployment/${svc} \
                                -n ${NAMESPACE} --timeout=120s
                        """
                    }
                }
            }
        }

        stage('ArgoCD Sync') {
            // Chỉ chạy nếu đã cài ArgoCD
            when { expression { return fileExists('argocd/app-dev.yaml') } }
            steps {
                withCredentials([string(credentialsId: 'argocd-token', variable: 'ARGOCD_TOKEN')]) {
                    sh """
                        argocd app sync yas-dev \
                            --server <argocd-server-nodeport> \
                            --auth-token \$ARGOCD_TOKEN \
                            --insecure
                    """
                }
            }
        }
    }

    post {
        success { echo "Dev deployed — image tag: main" }
        failure { echo "Dev deploy failed" }
    }
}