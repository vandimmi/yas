pipeline {
    agent any
    environment {
        DOCKERHUB_USER = 'vandiemmy'
        DOCKERHUB_CRED = credentials('dockerhub-cred')  // tạo credential trong Jenkins
    }
    triggers {
        githubPush()  // trigger khi có push lên bất kỳ branch nào
    }
    stages {
        stage('Get commit info') {
            steps {
                script {
                    env.COMMIT_ID = sh(
                        script: 'git rev-parse --short HEAD',
                        returnStdout: true
                    ).trim()
                    env.BRANCH_NAME_CLEAN = env.BRANCH_NAME.replaceAll('/', '_')
                    echo "Branch: ${env.BRANCH_NAME}, Commit: ${env.COMMIT_ID}"
                }
            }
        }
        stage('Build & Push images') {
            steps {
                script {
                    def services = ['tax', 'product', 'cart', 'order', 'customer',
                                    'rating', 'location', 'inventory', 'media', 'search']
                    sh "echo ${DOCKERHUB_CRED_PSW} | docker login -u ${DOCKERHUB_USER} --password-stdin"
                    for (svc in services) {
                        sh """
                            docker build -t ${DOCKERHUB_USER}/yas-${svc}:${COMMIT_ID} ./${svc}
                            docker push ${DOCKERHUB_USER}/yas-${svc}:${COMMIT_ID}
                        """
                    }
                }
            }
        }
    }
}